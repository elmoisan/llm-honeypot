# -----------------------------------------------
# LLM Honeypot — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# -----------------------------------------------

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Honeypot identity (what the server pretends to be)
FAKE_ORG=NeuralAPI Inc.
FAKE_DOMAIN=api.neuralgateway.io

# Logging
LOG_DIR=logs
LOG_FILE=logs/attacks.jsonl

# Dashboard port
DASHBOARD_PORT=8080

# Rate limiting (requests per IP per minute before flagging)
RATE_LIMIT=60/minute
